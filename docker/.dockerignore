# Build context is the creation-ops repo root. Keep it small: we only need the
# ComfyUI/ core source — no custom_nodes, no models, no sibling projects.

# Drop everything outside ComfyUI/, then re-include the core.
**/*
!ComfyUI/

# Inside ComfyUI/, drop everything that is not part of the core source.
ComfyUI/.git/
ComfyUI/.github/
ComfyUI/.ci/
ComfyUI/__pycache__/
ComfyUI/**/__pycache__/
ComfyUI/**/*.py[cod]

# Custom nodes are installed at runtime via ComfyUI-Manager — never bake them.
ComfyUI/custom_nodes/**

# Runtime state — must be mounted, never baked.
ComfyUI/models/**
ComfyUI/input/**
ComfyUI/output/**
ComfyUI/temp/**
ComfyUI/user/**

# Tests are not needed in a runtime image. (alembic_db/ IS needed — it holds
# the SQLAlchemy migrations the app applies on startup.)
ComfyUI/tests/
ComfyUI/tests-unit/

# Keep the placeholder file in input/ so default workflows still resolve.
!ComfyUI/input/example.png
